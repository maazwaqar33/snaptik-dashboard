# Copy to .env.local in apps/web and .env in apps/api
# DO NOT commit real values

# ===== Admin API (apps/api) =====
NODE_ENV=development
PORT=5001

# MongoDB (same URI as main snaptik backend)
MONGO_URI=mongodb://user:password@localhost:27017/snaptik

# Redis (same as main backend)
REDIS_URI=redis://localhost:6380

# JWT (generate with: openssl rand -base64 64)
JWT_ACCESS_SECRET=your_jwt_access_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# First Super Admin (used by seed script)
SEED_ADMIN_EMAIL=admin@snaptik.com
SEED_ADMIN_PASSWORD=changeme_immediately
SEED_ADMIN_NAME=Super Admin

# AWS (same account as main backend)
AWS_REGION=eu-north-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# AWS SES (for invite emails, password reset)
SES_FROM_EMAIL=noreply@snaptik.com
SES_FROM_NAME=SnapTik Admin

# AWS CloudFront (for signed video URLs in moderation)
CLOUDFRONT_DOMAIN=dmuignriz4m9z.cloudfront.net
CLOUDFRONT_KEY_PAIR_ID=your_cloudfront_key_pair_id
# Store private key content as env var (base64 encoded) OR as a file path:
CLOUDFRONT_PRIVATE_KEY=your_cloudfront_private_key_base64_encoded
# CLOUDFRONT_PRIVATE_KEY_PATH=./cloudfront-private-key.pem

# S3 (for exports bucket)
S3_BUCKET_EXPORTS=snaptik-admin-exports
S3_BUCKET_VIDEOS=snaptik-video

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# ===== Admin Web (apps/web) =====
NEXT_PUBLIC_API_URL=http://localhost:5001/api/v1
NEXT_PUBLIC_WS_URL=http://localhost:5001
