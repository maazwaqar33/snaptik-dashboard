NODE_ENV=development
PORT=5001

# Same MongoDB URI as main snaptik-backend
MONGODB_URI=mongodb://localhost:27017/snaptik

# JWT — use different secrets from main backend
JWT_ACCESS_SECRET=admin-access-secret-change-in-production-min-32-chars
JWT_REFRESH_SECRET=admin-refresh-secret-change-in-production-min-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Cookie settings (set secure:false for local dev)
COOKIE_SECURE=false
COOKIE_SAME_SITE=strict

# CORS — frontend URL
CORS_ORIGIN=http://localhost:3000

# AWS SES (optional — invite emails fall back to console.log if not set)
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_FROM_EMAIL=noreply@snaptik.com

# CloudFront (optional — for signed video URLs in moderation)
CLOUDFRONT_DOMAIN=
CLOUDFRONT_KEY_PAIR_ID=
CLOUDFRONT_PRIVATE_KEY=
